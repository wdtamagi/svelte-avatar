{
  "name": "svelte-avatar",
  "homepage": "https://svelte-avatar.netlify.app/",
  "keywords": [
    "svelte",
    "avatar",
    "component",
    "image",
    "initials",
    "profile"
  ],
  "version": "2.0.0",
  "description": "An avatar component for Svelte",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wdtamagi/svelte-avatar.git"
  },
  "bugs": {
    "url": "https://github.com/wdtamagi/svelte-avatar/issues"
  },
  "author": "Willian Dias Tamagi",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": [
    "**/*.svelte"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "svelte-package",
    "package:watch": "svelte-package --watch",
    "prepublishOnly": "npm run package",
    "preview": "vite preview",
    "test": "vitest"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "peerDependencies": {
    "svelte": ">=5"
  },
  "devDependencies": {
    "@sveltejs/package": "2.5.7",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.3.1",
    "jsdom": "28.1.0",
    "svelte": "5.53.6",
    "svelte-highlight": "6.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
