{
  "name": "svelte-avatar",
  "homepage": "https://svelte-avatar.netlify.app/",
  "keywords": [
    "svelte"
  ],
  "version": "1.2.0",
  "description": "An avatar component for Svelte",
  "repository": "git@github.com:wdtamagi/svelte-avatar.git",
  "author": "Willian Dias Tamagi",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "files": [
    "dist",
    "src/Avatar.svelte",
    "src/utils.js",
    "README.md"
  ],
  "svelte": "src/Avatar.svelte",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "start": "sirv public",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "0.4.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.3.1",
    "babel-jest": "29.7.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "rollup": "4.59.0",
    "rollup-plugin-livereload": "2.0.5",
    "rollup-plugin-svelte": "7.2.3",
    "sirv-cli": "3.0.1",
    "svelte": "5.53.6",
    "svelte-highlight": "6.2.1",
    "svelte-jester": "5.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.svelte\\.js$": "svelte-jester",
      "^.+\\.svelte$": "svelte-jester",
      "^.+\\.js$": "babel-jest"
    },
    "moduleFileExtensions": [
      "js",
      "svelte"
    ],
    "extensionsToTreatAsEsm": [
      ".svelte"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(@testing-library/svelte|@testing-library/svelte-core|svelte|esm-env)/)"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ]
  }
}
